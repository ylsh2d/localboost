# ================================================================
# LOCALBOOST — VARIABLES D'ENVIRONNEMENT
# Copiez ce fichier en ".env" et remplissez les valeurs
# NE JAMAIS mettre vos vraies valeurs dans .env.example
# Sur Render : copiez chaque ligne dans Environment Variables
# ================================================================

# SUPABASE (supabase.com > Project Settings > API)
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre-cle-anon-ici
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role-ici

# STRIPE (stripe.com > Developpeurs > Cles API)
STRIPE_SECRET_KEY=sk_test_votre-cle-ici
STRIPE_WEBHOOK_SECRET=whsec_votre-secret-ici
STRIPE_PRICE_STARTER=price_votre-id-starter-ici
STRIPE_PRICE_PRO=price_votre-id-pro-ici

# GOOGLE OAUTH (console.cloud.google.com > Identifiants)
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre-client-secret-ici

# META FACEBOOK/INSTAGRAM (optionnel - developers.facebook.com)
META_APP_ID=votre-app-id-ici
META_APP_SECRET=votre-app-secret-ici

# SITE
SITE_URL=http://localhost:3000
COOKIE_SECRET=mettez-une-longue-phrase-secrete-ici
PORT=3000
